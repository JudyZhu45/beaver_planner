// Secrets.example.xcconfig
// Copy this file to Secrets.xcconfig and fill in your real API keys.
// Secrets.xcconfig is gitignored and should never be committed.

// Get your API key from https://platform.moonshot.ai/
MOONSHOT_API_KEY = YOUR_API_KEY_HERE

// Get your API key from https://platform.openai.com/
OPENAI_API_KEY = YOUR_API_KEY_HERE

// Notion Integration for beta feedback collection
// 1. Go to https://www.notion.so/my-integrations → Create integration → copy "Internal Integration Secret"
// 2. Create a Notion database with columns: Name, Category, UserMessage, AIResponse, Note, AppVersion, SubmittedAt
// 3. Share that database with your integration (... menu → Add connections)
// 4. Copy the database ID from the URL: notion.so/YOUR_WORKSPACE/<DATABASE_ID>?v=...
NOTION_FEEDBACK_API_KEY = YOUR_NOTION_INTEGRATION_SECRET_HERE
NOTION_FEEDBACK_DATABASE_ID = YOUR_NOTION_DATABASE_ID_HERE
